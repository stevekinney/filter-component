{
  "name": "filter-component",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:conditional-braces": "bun run scripts/check-conditional-braces.ts",
    "check:react-compiler": "vite build --mode compiler-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --type-aware --deny-warnings && bun run check:conditional-braces",
    "lint:fix": "oxlint --fix --deny-warnings && bun run check:conditional-braces",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "preview": "vite preview",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:compiler": "vitest run --mode compiler-test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "validate": "bun run format:check && bun run lint && bun run lint:css && bun run typecheck && bun run check:react-compiler && bun run test:compiler && bun run test && bun run test:e2e && bun run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
