{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "jsx-a11y", "react", "typescript", "oxc", "unicorn"],
  "options": {
    "typeAware": true
  },
  "rules": {
    "complexity": ["error", { "max": 9, "variant": "modified" }],
    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
    "import/newline-after-import": ["error", { "count": 1 }],
    "react/react-compiler": ["error", { "reportAllBailouts": true }],
    "react/rules-of-hooks": "error",
    "react/only-export-components": ["warn", { "allowConstantExport": true }],
    "sort-imports": ["error", { "ignoreDeclarationSort": true }],
    "typescript/await-thenable": "error",
    "typescript/no-floating-promises": "error",
    "unicorn/filename-case": ["error", { "case": "kebabCase" }],
    "unicorn/no-nested-ternary": "error"
  },
  "overrides": [
    {
      // The filter uses APG composite widgets: focus remains on combobox/listbox
      // containers through aria-activedescendant, while token groups handle
      // keyboard input on divs. These rules assume individually focusable native
      // controls, so disable them only for the filter component.
      "files": ["src/components/filter/*.tsx"],
      "rules": {
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/no-noninteractive-element-interactions": "off",
        "jsx-a11y/no-noninteractive-tabindex": "off",
        "jsx-a11y/interactive-supports-focus": "off",
        "jsx-a11y/click-events-have-key-events": "off"
      }
    }
  ]
}
