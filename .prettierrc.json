{
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/(.*)$",
    "",
    "^@filter/(.*)$",
    "",
    "^[./]"
  ],
  "overrides": [
    {
      "files": "**/*.md",
      "options": {
        "printWidth": 80
      }
    }
  ]
}
